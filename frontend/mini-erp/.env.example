# Copy to .env.local. Dev khuyên dùng: KHÔNG set (hoặc xóa dòng) VITE_API_BASE_URL để
# fetch cùng origin; Vite proxy /api → http://127.0.0.1:8080 (envelope JSON, tránh lấy index.html).
# Nếu cần gọi thẳng 8080: bật CORS (smart-erp app.cors.allowed-origin-patterns).
# VITE_API_BASE_URL=http://localhost:8080
